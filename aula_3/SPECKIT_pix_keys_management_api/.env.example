# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pix_keys_db

# Application
APP_NAME=Pix Keys Management API
DEBUG=False

# Logging
LOG_LEVEL=INFO

# Business Rules
MAX_PIX_KEYS_PER_USER=5

# JWT/Auth (change in production)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
