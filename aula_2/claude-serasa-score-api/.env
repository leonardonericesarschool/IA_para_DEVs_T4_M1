# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/serasa_score

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SCORE_CACHE_TTL_SECONDS=86400

# ── Security ──────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SUBSTITUA_POR_UMA_CHAVE_SEGURA_DE_32_CARACTERES_OU_MAIS

# ── SERASA API ────────────────────────────────────────────────────────────────
SERASA_API_URL=https://api.serasa.com.br/v1
SERASA_API_KEY=SUA_CHAVE_SERASA_AQUI
SERASA_TIMEOUT_SECONDS=10
SERASA_MAX_RETRIES=3

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_IP=30
RATE_LIMIT_PER_TOKEN=100
